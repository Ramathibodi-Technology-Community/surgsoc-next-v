{
  "name": "surgsoc-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "check": "pnpm run lint && pnpm run typecheck",
    "vercel-build": "pnpm run check && pnpm run build",
    "payload": "payload",
    "generate:types": "payload generate:types",
    "generate:importmap": "pnpm exec payload generate:importmap",
    "db:up": "docker compose up -d payload-db",
    "db:reset": "tsx --import ./scripts/css-stub.mjs scripts/reset-db.ts",
    "db:seed": "tsx --import ./scripts/css-stub.mjs scripts/seed-db.ts",
    "db:migrate": "pnpm exec payload migrate",
    "db:refresh": "tsx --import ./scripts/css-stub.mjs scripts/refresh-db.ts",
    "db:fresh": "pnpm run db:migrate && pnpm run db:seed",
    "seed": "pnpm run db:seed",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "^3.76.1",
    "@payloadcms/email-resend": "^3.76.1",
    "@payloadcms/next": "^3.76.1",
    "@payloadcms/plugin-form-builder": "^3.76.1",
    "@payloadcms/richtext-lexical": "^3.76.1",
    "@payloadcms/ui": "^3.76.1",
    "@react-email/components": "^1.0.7",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/qrcode": "^1.5.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "^7.0.3",
    "dotenv": "^17.2.4",
    "embla-carousel": "^8.6.0",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.33.0",
    "graphql": "^16.8.1",
    "i18next": "^25.8.4",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.574.0",
    "mermaid": "^11.12.3",
    "next": "15.4.11",
    "openid-client": "^6.1.7",
    "payload": "^3.76.1",
    "qrcode": "^1.5.4",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-email": "^5.2.8",
    "react-i18next": "^16.5.4",
    "resend": "^6.9.1",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.1",
    "tailwindcss": "^4.1.18",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/escape-html": "^1.0.4",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^22.5.4",
    "@types/react": "19.0.1",
    "@types/react-dom": "19.0.1",
    "eslint": "^9",
    "eslint-config-next": "15.4.11",
    "postcss": "^8.5.6",
    "vitest": "^3.2.4",
    "tsx": "^4.21.0",
    "typescript": "5.7.2"
  },
  "engines": {
    "node": "22.x"
  },
  "packageManager": "pnpm@10.17.1"
}
