# --- Core Config ---
# The secret used to sign cookies/tokens. Make it long and zesty.
PAYLOAD_SECRET=your-super-secret-key-here
# The base URL of your site (use your Vercel production URL in production)
# Example: https://surgsoc.mahidol.edu
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# --- Database ---
# Your Postgres connection string (Supabase, Neon, or local)
DATABASE_URI=postgresql://user:password@localhost:5432/surgsoc

# --- Google OAuth ---
# From your Google Cloud Console
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Optional explicit callback override. If omitted, defaults to
# ${NEXT_PUBLIC_SERVER_URL}/api/auth/google/callback
GOOGLE_CALLBACK_URL=

# --- Email (Resend) ---
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=SurgSoc <noreply@surgsoc.mahidol.edu>
